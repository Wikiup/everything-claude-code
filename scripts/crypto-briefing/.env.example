# Daily Crypto Briefing — environment variables
# Copy to .env and fill in the two required values.

# Your Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Gmail App Password (NOT your regular Gmail password)
# How to get one:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Create an app password for "Mail" / "Other (Custom name)"
#   5. Paste the 16-character code here (no spaces)
SMTP_PASS=

# ── Optional overrides (Gmail defaults pre-configured) ────────────────────────
# BRIEFING_EMAIL=marketertribe@gmail.com   # already set as default
# SMTP_FROM=marketertribe@gmail.com        # already set as default
# SMTP_USER=marketertribe@gmail.com        # already set as default
# SMTP_HOST=smtp.gmail.com                 # already set as default
# SMTP_PORT=587                            # already set as default
